# .streamlit/secrets.toml.example
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to  .streamlit/secrets.toml  and fill in real values.
# secrets.toml is git-ignored — never commit real tokens to the repository.
#
# On Streamlit Cloud: paste these key=value pairs into
#   App → Settings → Secrets
# ─────────────────────────────────────────────────────────────────────────────

# Optional: HuggingFace access token.
# Only required if your dataset repo is PRIVATE.
# Generate at: https://huggingface.co/settings/tokens (read-only scope)
HF_TOKEN = ""
